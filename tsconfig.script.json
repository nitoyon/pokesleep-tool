{
	"compilerOptions": {
		"target": "es2022",
		"lib": ["dom", "dom.iterable", "esnext"],
		"types": ["node"],
		"allowJs": true,
		"noImplicitAny": true,
		"skipLibCheck": false,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"isolatedModules": false,
		"resolveJsonModule": true,
		"noEmit": true,
		"jsx": "preserve"
	},
	"include": ["scripts"]
}
